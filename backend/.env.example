# === Database ===
DATABASE_URL=postgresql+asyncpg://compa:compa@localhost:5432/compa
REDIS_URL=redis://localhost:6379

# === AI ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# === 로컬 AI (Ollama) — USE_LOCAL_AI=true 시 Claude API 대신 사용 ===
USE_LOCAL_AI=false
OLLAMA_URL=http://localhost:11434
LOCAL_AI_MODEL=qwen2.5:14b

# === 쇼핑 API ===
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
RAKUTEN_APP_ID=
RAKUTEN_AFFILIATE_ID=
COUPANG_PARTNER_ID=

# === 소셜 ===
INSTAGRAM_ACCESS_TOKEN=
TIKTOK_CLIENT_KEY=

# === 스크래핑 ===
FIRECRAWL_URL=http://localhost:8765
FIRECRAWL_EXTRACT_PROVIDER=local
PROXY_POOL_URL=

# === 보안 / 운영 ===
ADMIN_SECRET=change-me-in-production
PREMIUM_API_KEYS=

# === CORS — 쉼표 구분, 공백 허용 ===
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# === 스크래퍼 활성화 토글 — 쉼표 구분, "all" 이면 전체 ===
ENABLED_SCRAPERS=네이버쇼핑,Rakuten
